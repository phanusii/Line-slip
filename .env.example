# ── Supabase ──────────────────────────────────────────────────────────────────
# Project URL: Settings → API → Project URL
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co

# Service Role Key (secret): Settings → API → service_role (ไม่ใช่ anon key)
SUPABASE_SERVICE_ROLE_KEY=eyJxxx...

# ชื่อ Storage Bucket (ค่าเริ่มต้น: slips — ตรงกับ migration)
SUPABASE_SLIPS_BUCKET=slips

# ── Application ───────────────────────────────────────────────────────────────
# URL สาธารณะของแอป เช่น https://yourapp.vercel.app (ไม่มี trailing slash)
# ใช้ต่อลิงก์ external-review ที่ส่งไป Telegram/Discord
NEXT_PUBLIC_APP_URL=https://yourapp.vercel.app

# ── LINE Platform ─────────────────────────────────────────────────────────────
# Channel Secret: LINE Developers → Messaging API → Channel secret
LINE_CHANNEL_SECRET=

# Channel Access Token (Long-lived): LINE Developers → Messaging API → Channel access token
LINE_CHANNEL_ACCESS_TOKEN=

# LIFF App ID: LINE Developers → LIFF → App ID (รูปแบบ xxxxxxxxxx-xxxxxxxx)
NEXT_PUBLIC_LIFF_ID=

# Channel ID ของ LIFF (เพื่อตรวจ access token): LINE Developers → Basic settings → Channel ID
LINE_LIFF_CHANNEL_ID=

# ── Admin Credentials ─────────────────────────────────────────────────────────
# อีเมล admin หลัก (สำหรับ login ครั้งแรก)
ADMIN_EMAIL=admin@example.com

# Password hash — สร้างด้วย: node scripts/hash-password.mjs YOUR_PASSWORD
ADMIN_PASSWORD_HASH=scrypt$...

# Secret สำหรับเซ็น session cookie (random string อย่างน้อย 32 ตัวอักษร)
# สร้างด้วย: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ADMIN_SESSION_SECRET=

# ── External Review (Telegram/Discord one-click) ──────────────────────────────
# Secret แยกสำหรับเซ็น token อนุมัติ/ปฏิเสธสลิปจาก Telegram/Discord
# ถ้าเว้นว่าง ระบบจะใช้ ADMIN_SESSION_SECRET แทน
ADMIN_REVIEW_TOKEN_SECRET=
